# Database (PostgreSQL — Azure for production)
# Use a separate `ticketr` database on the idea_hackathon server:

# Auth (required)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="https://ticketr.ideahackathon.com"
NEXT_PUBLIC_APP_URL="https://ticketr.ideahackathon.com"

# App name in email subjects
TICKETR_NAME="ticketr"

# Email — ZeptoMail (required for notifications)
ZEPTO_API_KEY=""
ZEPTO_FROM_ADDRESS="ticketr@ideahackathon.com"
ZEPTO_FROM_NAME="ticketr"
# India data center only:
# ZEPTO_API_URL="https://api.zeptomail.in/v1.1/email"

# File attachments — reuse iDEA hackathon R2 bucket (same vars as idea Vercel project)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""
# Object key prefix (idea uses avatars/; ticketr uses ticketr/attachments/)
R2_KEY_PREFIX="ticketr/attachments"

# OAuth — optional
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED="false"

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
NEXT_PUBLIC_GITHUB_OAUTH_ENABLED="false"

# Local dev only
# DATABASE_URL="postgresql://ticketr:ticketr@localhost:5432/ticketr"
# AUTH_URL="http://localhost:3000"
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
