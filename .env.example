# Database (PostgreSQL — required for Docker / Azure)
DATABASE_URL="postgresql://ticketr:ticketr@localhost:5432/ticketr"

# Auth (required)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Set to "true" on first container start to load demo users/categories
SEED_DATABASE="false"

# Email notifications (ZeptoMail) — optional
ZEPTO_API_KEY=""
ZEPTO_FROM_ADDRESS=""
ZEPTO_FROM_NAME="ticketr"
# India data center (optional; default is api.zeptomail.com)
ZEPTO_API_URL=""

# OAuth — set client IDs/secrets and enable flags for UI buttons
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED="false"

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
NEXT_PUBLIC_GITHUB_OAUTH_ENABLED="false"

# File attachments (Cloudflare R2) — optional
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""
